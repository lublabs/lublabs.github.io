---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

const caseStudies = (await getCollection("case-studies")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Case Studies | LubLabs" description="Product and software delivery case studies from LubLabs.">
  <section class="hero content-shell">
    <p class="eyebrow">Case studies</p>
    <h1 class="page-title">Real products delivered with clear business outcomes.</h1>
    <p class="lede page-lede">
      These pages showcase the technical depth, delivery process, and measurable impact LubLabs creates.
    </p>
  </section>

  <section class="section card-grid content-listing content-shell">
    {caseStudies.map((study) => (
      <article class="card listing-card">
        <a href={`/case-studies/${study.slug}/`}>
          <Image
            src={study.data.image}
            alt={`${study.data.title} cover image`}
            class="case-study-image mb-4"
            loading="lazy"
          />
        </a>
        <h2>
          <a href={`/case-studies/${study.slug}/`}>{study.data.title}</a>
        </h2>
        <p>{study.data.summary}</p>
        <div class="meta listing-meta">
          <span>{study.data.client}</span>
          <span>{study.data.industry}</span>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
