---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Services | LubLabs" description="Web, mobile, and AI engineering services by LubLabs.">
  <section class="hero">
    <p class="eyebrow">Services</p>
    <h1>Engineering services designed to turn product ideas into shipped outcomes.</h1>
    <p class="lede">
      Use this page as your services foundation while we migrate your full conversion copy and design system.
    </p>
  </section>

  <section class="section">
    <div class="card-grid three">
      <article class="card">
        <h3>Web App Development</h3>
        <p>Scalable web platforms with clear architecture and reliable performance.</p>
      </article>
      <article class="card">
        <h3>Mobile App Development</h3>
        <p>Production-ready iOS and Android experiences with clean, maintainable codebases.</p>
      </article>
      <article class="card">
        <h3>AI and Automation</h3>
        <p>Practical AI features and workflow automation designed for measurable business impact.</p>
      </article>
    </div>
  </section>
</BaseLayout>
