---
import SiteFooter from "../components/SiteFooter";
import SiteNav from "../components/SiteNav";
import ScrollReveal from "../components/ScrollReveal.astro";
import "../styles/global.css";
import "../styles/tailwind.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LubLabs",
  description = "LubLabs builds high-quality software for startups and SMBs.",
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;600;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-body bg-[#F6F1E8] text-[#1F1A14]">
    <SiteNav currentPath={currentPath} />
    <ScrollReveal />

    <script is:inline>
      (() => {
        const nav = document.querySelector("[data-site-nav]");
        if (!nav) {
          return;
        }

        const syncNavState = () => {
          nav.classList.toggle("is-scrolled", window.scrollY > 10);
        };

        syncNavState();
        window.addEventListener("scroll", syncNavState, { passive: true });
      })();
    </script>

    <main class="site-main">
      <div class="container">
        <slot />
      </div>
    </main>

    <SiteFooter />
  </body>
</html>
